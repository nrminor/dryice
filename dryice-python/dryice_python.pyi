from typing import Iterator, Optional

class WriterBuilder:
    """Builder for configuring a DryIce writer."""

    def __init__(self) -> None: ...
    def two_bit_exact(self) -> WriterBuilder: ...
    def two_bit_lossy_n(self) -> WriterBuilder: ...
    def binned_quality(self) -> WriterBuilder: ...
    def split_names(self) -> WriterBuilder: ...
    def bytes8_key(self) -> WriterBuilder: ...
    def prefix_kmers(self) -> WriterBuilder: ...
    def prefix_kmers_with_sequences(self) -> WriterBuilder: ...
    def prefix_kmers_with_names(self) -> WriterBuilder: ...
    def minimizers(self) -> WriterBuilder: ...
    def minimizers_with_sequences(self) -> WriterBuilder: ...
    def minimizers_with_names(self) -> WriterBuilder: ...
    def target_block_records(self, n: int) -> WriterBuilder: ...
    def build(self) -> Writer: ...
    def build_temp(self, temp_file: TempFile) -> TempWriter: ...

class Writer:
    """A dryice file writer."""

    @staticmethod
    def builder() -> WriterBuilder: ...
    def write_record(self, name: bytes, sequence: bytes, quality: bytes) -> None: ...
    def write_record_with_key(
        self, name: bytes, sequence: bytes, quality: bytes, key: bytes
    ) -> None: ...
    def finish(self) -> bytes: ...

class TempWriter:
    """A file-backed dryice writer owned by a TempFile."""

    def write_record(self, name: bytes, sequence: bytes, quality: bytes) -> None: ...
    def write_record_with_key(
        self, name: bytes, sequence: bytes, quality: bytes, key: bytes
    ) -> None: ...
    def finish(self) -> None: ...

class TempFile:
    """An owned temporary dryice file that cleans itself up by default."""

    path: str

    def __init__(self) -> None: ...
    def __enter__(self) -> TempFile: ...
    def __exit__(self, exc_type: object, exc_value: object, traceback: object) -> bool: ...
    def cleanup(self) -> None: ...
    def persist(self, path: str) -> str: ...

class Record:
    """A decoded sequencing record."""

    name: Optional[bytes]
    sequence: Optional[bytes]
    quality: Optional[bytes]
    key: Optional[bytes]

class ReaderBuilder:
    """Builder for configuring a DryIce reader."""

    def __init__(self) -> None: ...
    def two_bit_exact(self) -> ReaderBuilder: ...
    def two_bit_lossy_n(self) -> ReaderBuilder: ...
    def binned_quality(self) -> ReaderBuilder: ...
    def split_names(self) -> ReaderBuilder: ...
    def bytes8_key(self) -> ReaderBuilder: ...
    def prefix_kmers(self) -> ReaderBuilder: ...
    def prefix_kmers_with_sequences(self) -> ReaderBuilder: ...
    def prefix_kmers_with_names(self) -> ReaderBuilder: ...
    def minimizers(self) -> ReaderBuilder: ...
    def minimizers_with_sequences(self) -> ReaderBuilder: ...
    def minimizers_with_names(self) -> ReaderBuilder: ...
    def build(self, data: bytes) -> Reader: ...
    def build_temp(self, temp_file: TempFile) -> Reader: ...

class Reader:
    """A dryice file reader."""

    @staticmethod
    def builder() -> ReaderBuilder: ...
    @staticmethod
    def open(data: bytes) -> Reader: ...
    def __iter__(self) -> Iterator[Record]: ...
    def __next__(self) -> Record: ...

def open_projected(
    data: bytes,
    projection: str,
    sequence_codec: str = "raw",
    quality_codec: str = "raw",
    name_codec: str = "raw",
    record_key: str = "none",
) -> Reader: ...
def default_prefix_kmer_key(sequence: bytes) -> Optional[bytes]: ...
def default_minimizer_key(sequence: bytes) -> Optional[bytes]: ...
def temp_file() -> TempFile: ...
