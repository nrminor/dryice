# Deny-by-default: ignore everything, explicitly allow tracked files.
# All file tracking is intentional. No glob patterns allowed.
*

# === Allowed: project configuration ===
!/.gitignore
!/Cargo.toml
!/Cargo.lock
!/justfile
!/rustfmt.toml
!/AGENTS.md
!/README.md
!/LICENSE

# === Allowed: agent configuration ===
!/.agents
!/.agents/dryice-design-first-pass.md
!/.agents/dryice-rust-architecture-plan.md
!/.agents/dryice-rust-design-notebook.md
!/.agents/dryice-consolidated-work-plan.md

# === Allowed: core crate ===
!/dryice
!/dryice/Cargo.toml
!/dryice/src
!/dryice/src/lib.rs

# === Allowed: GitHub workflows ===
!/.github
!/.github/workflows
!/.github/workflows/build-rust.yaml
!/.github/workflows/open-source-starter.yml
